{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "checkJs": true,

    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "#src/*": ["src/*"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist", "tests"]
}
