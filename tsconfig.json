{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "checkJs": true,

    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "#src/*": ["src/*"]
    }
  },
  "include": ["index.ts", "src", "bin"],
  "exclude": ["node_modules", "dist", "tests"]
}
