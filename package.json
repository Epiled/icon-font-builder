{
  "name": "@epiled/icon-font-builder",
  "version": "1.0.0",
  "description": "Generate icon fonts from SVG files",
  "type": "module",
  "main": "index.js",
  "bin": {
    "icon-font-builder": "./bin/cli.js"
  },
  "keywords": [
    "icons",
    "icon-font",
    "svg",
    "font",
    "webfont"
  ],
  "author": "Felipe De Andrade (https://github.com/epiled)",
  "license": "MIT",
  "homepage": "https://github.com/epiled/icon-font-builder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epiled/icon-font-builder.git"
  },
  "bugs": {
    "url": "https://github.com/epiled/icon-font-builder/issues"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "bin",
    "src",
    "index.js"
  ],
  "dependencies": {
    "handlebars": "^4.7.8",
    "svg2ttf": "^6.0.3",
    "svgicons2svgfont": "^15.0.1",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.1"
  },
  "devDependencies": {
    "tree-cli": "^0.6.7",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest",
    "prepublishOnly": "npm test",
    "build:icons": "node scripts/build-default.js",
    "build:icons:dev": "node scripts/build-dev.js",
    "build:icons:dev:log": "node scripts/build-dev-glyphs.js",
    "tree-cli": "npx tree-cli -l 5 -a --markdown --ignore node_modules/,build/,.git/,.next/,coverage/,out/,tmp/,temp/ ./ -o structure.md"
  }
}
